<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/layoutBall"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_gravity="end|center_vertical"
        android:background="@android:drawable/toast_frame"
        android:backgroundTint="#FF4081"
        android:elevation="8dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="📸"
            android:textSize="22sp" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layoutPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC222222"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layoutResizeHandle"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:gravity="center"
            android:background="#11FFFFFF"
            android:layout_marginBottom="8dp"
            android:orientation="vertical">

            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:background="#88FFFFFF" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnCaptureAndUpload"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:backgroundTint="#FF4081"
                android:text="📸 立即截屏解析"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMinimize"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#607D8B"
                android:text="➖ 收起"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnCloseFloat"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#FF5722"
                android:text="❌ 退出"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollResultContainer"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#33FFFFFF"
            android:padding="8dp"
            android:scrollbars="vertical"
            android:fadeScrollbars="false"
            android:scrollbarSize="6dp"
            android:scrollbarThumbVertical="@android:color/white">

            <TextView
                android:id="@+id/tvResultDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请点击左侧按钮开始截图..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.2" />
        </ScrollView>
    </LinearLayout>
</FrameLayout>